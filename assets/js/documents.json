---
layout: null
sitemap: false
---
{% assign counter = 0 %}
{% assign all_docs = site.pages | concat: site.posts %}
{% if site.ideas %}{% assign all_docs = all_docs | concat: site.ideas %}{% endif %}
{% if site.fermentland %}{% assign all_docs = all_docs | concat: site.fermentland %}{% endif %}
{% if site.aboutme %}{% assign all_docs = all_docs | concat: site.aboutme %}{% endif %}
{% if site.failedprojects %}{% assign all_docs = all_docs | concat: site.failedprojects %}{% endif %}

[
{% assign first_doc = true %}
{% for doc in all_docs %}
    {% if doc.url contains '.xml' or doc.url contains '.txt' or doc.url contains 'assets' or doc.url contains 'category' or doc.url contains 'tag' or doc.url == '/ideas' or doc.url == '/fermentland' or doc.url == '/failed-projects' %}
        {% continue %}
    {% endif %}
    {% unless first_doc %},{% endunless %}
    {
    "id": {{ counter }},
    "url": "{{ doc.url | relative_url }}",
    "title": {{ doc.title | jsonify }},
    "body": {{ doc.content | strip_html | strip_newlines | truncatewords: 35, "" | jsonify }}
    }
    {% assign counter = counter | plus: 1 %}
    {% assign first_doc = false %}
{% endfor %}
]